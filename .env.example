# Copy to .env and adjust. Mock mode runs on any machine; real mode only on the Pi.
# HYDRO_MODE=sim   # mechanistic digital-twin backend (closed-loop virtual grow);
#                  # pair with HYDRO_PROFILE=profiles/bench-sim.yaml
HYDRO_MODE=mock

# Deployment profile — declares every device (count/type/binding). See
# docs/profile-authoring.md. Default reproduces the Phase-1 bench rig.
HYDRO_PROFILE=profiles/bench.yaml

# Service
HYDRO_HOST=0.0.0.0
HYDRO_PORT=8000

# Storage
HYDRO_DB_PATH=data/hydro.db
HYDRO_RETENTION_HOURS=24

# Sampling
HYDRO_POLL_SECONDS=10

# Pump dosing — measured flow rate, refine post-wiring (see docs/calibration.md)
HYDRO_PUMP_ML_PER_MIN=50

# Calibration file (pH)
HYDRO_CALIBRATION_PATH=data/calibration.json
