# Hydro runtime config for the Pi.
# Copy this to .env before first run and adjust mode if wiring is live.

HYDRO_MODE=mock
HYDRO_HOST=0.0.0.0
HYDRO_PORT=8000
HYDRO_DB_PATH=data/hydro.db
HYDRO_POLL_SECONDS=10
HYDRO_RETENTION_HOURS=24
HYDRO_PUMP_ML_PER_MIN=50.0
HYDRO_CALIBRATION_PATH=data/calibration.json
